# ========== 必填 ==========
# 接收通知的 QQ 号
QQ_ID=你的QQ号

# 教务系统账号密码
JW_USERNAME=你的学号
JW_PASSWORD=你的密码

# ========== 可选（一般不用改） ==========
# 检查间隔（分钟）
CHECK_INTERVAL_MINUTES=30

# 教务系统地址
JW_BASE_URL=https://jwglxt.gpnu.edu.cn
JW_AUTH_URL=https://webauth.gpnu.edu.cn

# NoneBot2 驱动和 OneBot 连接（Docker 部署不要改）
# DRIVER=~websockets
# ONEBOT_WS_URLS=["ws://napcat:3001"]
# LOG_LEVEL=INFO
